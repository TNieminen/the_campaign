<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>TheCampaign</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <!-- Exclude duplicate StoryEngine (use Assets copy only) and Unity internals so the C# linter sees a single type definition. -->
  <!-- Exclude tests (they are built by the test project in tests/). -->
  <!-- Exclude Unity-only scripts (no UnityEngine when building from CLI). -->
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
    <Compile Remove="src/StoryEngine/**/*.cs" />
    <Compile Remove="src/**/Library/**/*.cs" />
    <Compile Remove="src/**/PackageCache/**/*.cs" />
    <Compile Remove="src/Assets/Scripts/Story/StorySceneController.cs" />
    <Compile Remove="src/Temp/**/*.cs" />
  </ItemGroup>
</Project>

